# MongoDB Connection URI (set this to your NEW MongoDB instance)
# Example Atlas URI: mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
MONGODB_URI=

# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_here

# Node Environment
NODE_ENV=development

# Port (optional, defaults to 3000 or next available)
PORT=3000

# Frontend API endpoint for static deployments (Vercel/GitHub Pages)
# Example: https://your-backend-domain.com
VITE_API_URL=

# Allow specific frontend origins for CORS (comma-separated)
# Example: https://your-app.vercel.app,https://<username>.github.io
CORS_ORIGIN=

# Use hash router for static hosting fallback compatibility (optional)
# true for GitHub Pages, false for normal server hosting
VITE_USE_HASH_ROUTER=false

# Optional base path for GitHub Pages project sites, e.g. /veventa_final/
VITE_BASE_PATH=/
